{% extends "_layouts/cp" %}

{% set title = "Connections"|t('webhook-notifier') %}
{% set selectedSubnavItem = 'connections' %}

{% block actionButton %}
    <a href="{{ url('webhook-notifier/connections/new') }}" class="btn submit add icon">{{ "New connection"|t('webhook-notifier') }}</a>
{% endblock %}

{% block content %}
    <p class="light" style="margin-bottom:24px; max-width:48em">
        {{ "A connection is somewhere to send notifications - any webhook URL. That might be a Microsoft Teams channel (via Power Automate Workflows), or Zapier, Slack, a custom endpoint, and so on. Add one, send a test to check it responds, then point your rules at it."|t('webhook-notifier') }}
    </p>

    {% if connections|length %}
        <table class="data fullwidth">
            <thead>
                <tr>
                    <th scope="col">{{ "Name"|t('webhook-notifier') }}</th>
                    <th scope="col">{{ "Webhook"|t('webhook-notifier') }}</th>
                    <th scope="col">{{ "Enabled"|t('webhook-notifier') }}</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>
                {% for connection in connections %}
                    <tr>
                        <th scope="row" data-title="{{ 'Name'|t('webhook-notifier') }}">
                            <a href="{{ url('webhook-notifier/connections/' ~ connection.id) }}">{{ connection.name }}</a>
                        </th>
                        <td data-title="{{ 'Webhook'|t('webhook-notifier') }}">
                            <code>{{ maskedUrls[connection.id] ?? '' }}</code>
                            {% if connection.isEnvVar %}
                                <span class="light">({{ "env var"|t('webhook-notifier') }})</span>
                            {% endif %}
                        </td>
                        <td data-title="{{ 'Enabled'|t('webhook-notifier') }}">
                            {% if connection.enabled %}<span class="status green"></span> {{ "Yes"|t('webhook-notifier') }}{% else %}<span class="status"></span> {{ "No"|t('webhook-notifier') }}{% endif %}
                        </td>
                        <td class="thin nowrap">
                            <form method="post" style="display:inline">
                                {{ csrfInput() }}
                                {{ actionInput('webhook-notifier/connections/test') }}
                                {{ redirectInput('webhook-notifier/connections') }}
                                {{ hiddenInput('id', connection.id) }}
                                <button type="submit" class="btn small">{{ "Send test"|t('webhook-notifier') }}</button>
                            </form>
                            <form method="post" style="display:inline" onsubmit="return confirm('{{ 'Delete this connection?'|t('webhook-notifier') }}')">
                                {{ csrfInput() }}
                                {{ actionInput('webhook-notifier/connections/delete') }}
                                {{ redirectInput('webhook-notifier/connections') }}
                                {{ hiddenInput('id', connection.id) }}
                                <button type="submit" class="btn small delete">{{ "Delete"|t('webhook-notifier') }}</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>{{ "No connections yet."|t('webhook-notifier') }}</p>
        <p>{{ "A connection holds one webhook URL - a Microsoft Teams channel, or any other webhook (Zapier, Slack, a custom endpoint…)."|t('webhook-notifier') }}</p>
    {% endif %}
{% endblock %}
