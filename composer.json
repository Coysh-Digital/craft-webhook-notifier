{
    "name": "coysh-digital/craft-webhook-notifier",
    "description": "Rule-driven webhook notifications for Craft CMS - fire any Craft event at any webhook, with first-class Microsoft Teams (Adaptive Card) support.",
    "version": "1.5.2",
    "type": "craft-plugin",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "microsoft-teams",
        "teams",
        "notifications",
        "webhooks",
        "adaptive-cards"
    ],
    "license": "proprietary",
    "support": {
        "email": "support@coysh.digital",
        "issues": "https://github.com/Coysh-Digital/craft-webhook-notifier/issues",
        "source": "https://github.com/Coysh-Digital/craft-webhook-notifier",
        "docs": "https://github.com/Coysh-Digital/craft-webhook-notifier/blob/main/README.md"
    },
    "authors": [
        {
            "name": "Coysh Digital",
            "homepage": "https://coysh.digital"
        }
    ],
    "require": {
        "php": ">=8.2",
        "craftcms/cms": "^5.0.0"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main",
        "solspace/craft-freeform": "^5.0"
    },
    "suggest": {
        "solspace/craft-freeform": "Adds a 'Freeform submission' notification source (^5.0)."
    },
    "autoload": {
        "psr-4": {
            "coyshdigital\\webhooknotifier\\": "src/"
        }
    },
    "extra": {
        "name": "Webhook Notifier",
        "handle": "webhook-notifier",
        "developer": "Coysh Digital",
        "developerUrl": "https://coysh.digital",
        "documentationUrl": "https://github.com/Coysh-Digital/craft-webhook-notifier/blob/main/README.md",
        "changelogUrl": "https://raw.githubusercontent.com/Coysh-Digital/craft-webhook-notifier/main/CHANGELOG.md",
        "class": "coyshdigital\\webhooknotifier\\Plugin",
        "components": {
            "connections": "coyshdigital\\webhooknotifier\\services\\Connections",
            "rules": "coyshdigital\\webhooknotifier\\services\\Rules",
            "sources": "coyshdigital\\webhooknotifier\\services\\Sources",
            "conditions": "coyshdigital\\webhooknotifier\\services\\Conditions",
            "cards": "coyshdigital\\webhooknotifier\\services\\Cards",
            "sender": "coyshdigital\\webhooknotifier\\services\\Sender",
            "deliveries": "coyshdigital\\webhooknotifier\\services\\Deliveries"
        }
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    },
    "scripts": {
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --fix --ansi",
        "phpstan": "phpstan analyse --memory-limit=1G"
    }
}
